rules_version = '2';

// -----------------------------------------------------------------------------
// Firestore 安全規則 — maple-classic-calc / exp_records（社群資料庫）
//
// 部署方式：
//   1. 推上 main 就會由 .github/workflows/deploy.yml 自動部署；
//      手動部署用 CLI： firebase deploy --only firestore:rules
//   2. App Check 已啟用且為強制執行（reCAPTCHA Enterprise provider，
//      2026-07 由 classic v3 換過來），擋機器人濫用寫入 / 灌讚。
//
// 設計原則（匿名公開資料庫）：
//   - 任何人可讀。
//   - 新增紀錄要通過欄位型別 / 範圍 / 長度驗證，擋掉超大 payload 與髒資料。
//   - 更新只允許「helpful 讚數 +1」，其他欄位一律不可改。
//   - 不允許刪除、不允許改動既有內容。
//
// 濫用滅火開關（規則擋得住格式不合法的資料，擋不住真瀏覽器灌「格式合法」
// 的垃圾回報——上線初期建議每天看一眼資料量）。發現灌水時一個 commit 關閉回報：
//   1. 下面的 allow create 改成 `allow create: if false;`
//   2. js/community.js 的 SUBMISSIONS_OPEN 改成 false（入口按鈕會鎖住）
//   兩邊要一起改，推上 main 就會同時部署規則與前端。
// -----------------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {

    match /exp_records/{recordId} {

      // 允許的職業，須跟前端 js/jobsData.js 的 JOBS_DATA[].paths[].fourth 保持一致
      // （前端 3 個 <select> 的選項都是從那份資料動態產生的單一來源）。
      // Firestore 規則沒辦法讀取前端 JS，所以改 jobsData.js 的職業名稱時，
      // 一定要手動同步更新這裡，否則使用者選到的職業會被下面 create 規則擋掉。
      function allowedJobs() {
        return [
          '英雄', '聖騎士', '黑騎士',
          '火毒大魔導士', '冰雷大魔導士', '主教',
          '箭神', '神射手',
          '夜使者', '暗影神偷',
          '拳霸', '槍神'
        ];
      }

      function isValidNew(d) {
        return d.keys().hasAll(['job', 'map', 'level', 'expPer10Min', 'helpful', 'ts'])
          && d.keys().hasOnly(['job', 'map', 'level', 'expPer10Min', 'helpful', 'note', 'ts'])
          && d.job is string && allowedJobs().hasAny([d.job])
          && d.map is string && d.map.size() >= 1 && d.map.size() <= 40
          && d.level is int && d.level >= 1 && d.level <= 200
          && d.expPer10Min is int && d.expPer10Min > 0 && d.expPer10Min <= 1000000000
          && d.helpful == 0
          && d.ts == request.time
          && (!('note' in d.keys()) || (d.note is string && d.note.size() <= 60));
      }

      // 只能改 helpful，且必須是 +1（防止一次灌大量讚 / 竄改其他欄位）
      function isHelpfulIncrement() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpful'])
          && request.resource.data.helpful == resource.data.helpful + 1;
      }

      // list 要求帶 limit（且不超過 100），擋掉直接打 API 整包撈走整個集合；
      // 前端實際查詢帶的 limit 是 PAGE_SIZE+1=51（js/community.js，多抓 1 筆
      // 判斷還有沒有下一頁），100 留一點餘裕。
      allow get: if true;
      allow list: if request.query.limit <= 100;
      allow create: if isValidNew(request.resource.data);
      allow update: if isHelpfulIncrement();
      allow delete: if false;
    }

    match /team_posts/{postId} {

      // 跟 exp_records 的 allowedJobs() 是同一份白名單，Firestore 規則的
      // function 只在宣告它的 match 區塊內有效，沒辦法跨 match 共用，
      // 所以這裡重複宣告一次——改職業名稱時兩處都要同步（跟 js/jobsData.js
      // 的 JOBS_DATA[].paths[].fourth 一致）。
      function allowedJobs() {
        return [
          '英雄', '聖騎士', '黑騎士',
          '火毒大魔導士', '冰雷大魔導士', '主教',
          '箭神', '神射手',
          '夜使者', '暗影神偷',
          '拳霸', '槍神'
        ];
      }

      function allowedServers() {
        return ['雪吉拉', '菇菇寶貝'];
      }

      // target（目標）不比對完整清單：本來想接 js/teamData.js 的野王/任務
      // 清單，但遊戲還沒上線、實際名稱不確定，前端已經改自由輸入，這裡只守
      // 型別/長度，跟 exp_records 的 map 欄位同一個處理方式。
      //
      // scheduledAt（集合時間，使用者填的，不是伺服器蓋章）允許比現在早最多
      // 1 小時（給「現在就要揪」一點緩衝）、最多提前 7 天，跟 js/team.js 的
      // MIN_PAST_MS／MAX_ADVANCE_MS 常數要保持一致，這裡改了那裡也要跟著改。
      function isValidNew(d) {
        return d.keys().hasAll(['type', 'target', 'server', 'map', 'job', 'level', 'currentCount', 'neededCount', 'contact', 'scheduledAt', 'ts'])
          && d.keys().hasOnly(['type', 'target', 'server', 'map', 'job', 'level', 'currentCount', 'neededCount', 'contact', 'scheduledAt', 'note', 'ts'])
          && d.type is string && d.type in ['組隊任務', '王團']
          && d.target is string && d.target.size() >= 1 && d.target.size() <= 40
          && d.server is string && allowedServers().hasAny([d.server])
          && d.map is string && d.map.size() >= 1 && d.map.size() <= 40
          && d.job is string && allowedJobs().hasAny([d.job])
          && d.level is int && d.level >= 1 && d.level <= 200
          && d.currentCount is int && d.currentCount >= 0 && d.currentCount <= 6
          && d.neededCount is int && d.neededCount >= 1 && d.neededCount <= 6
          && d.currentCount <= d.neededCount
          && d.contact is string && d.contact.size() >= 1 && d.contact.size() <= 40
          && d.scheduledAt is timestamp
          && d.scheduledAt >= request.time - duration.value(1, 'h')
          && d.scheduledAt <= request.time + duration.value(7, 'd')
          && d.ts == request.time
          && (!('note' in d.keys()) || (d.note is string && d.note.size() <= 60));
      }

      // 只能把 found 從沒設定/false 改成 true，不能改別的欄位、也不能
      // 反悔改回 false（跟 exp_records 的 isHelpfulIncrement() 同一種
      // 「只開放一個安全的部分更新」寫法）。這裡沒有比對「是不是本人在改」
      // ——沒有帳號系統做不到真的驗證，前端用 localStorage 記自己發過的
      // 文件 ID 決定要不要顯示這顆按鈕，是 UI 層的軟性限制，不是安全機制；
      // 就算被任何人手動呼叫改掉，最壞情況也只是這篇貼文提早消失，
      // 影響很小，不值得為此增加複雜度。
      function isMarkFound() {
        // found 在建立時不會被寫入（create 規則的 hasOnly 沒有這個欄位），
        // 所以第一次標記時 resource.data 裡根本沒有 found 這個 key——直接
        // resource.data.found 對不存在的欄位取值會噴錯，要用 get() 給預設值
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['found'])
          && request.resource.data.found == true
          && resource.data.get('found', false) != true;
      }

      // 不開放刪除；到期後前端用 6 小時的時間窗自動從列表濾掉就好，不需要
      // 真的刪除資料。之後如果資料量長很大，可以另外設 Firestore 原生
      // TTL policy 清掉舊資料（見 team.js 開頭註解）。
      allow get: if true;
      allow list: if request.query.limit <= 100;
      allow create: if isValidNew(request.resource.data);
      allow update: if isMarkFound();
      allow delete: if false;
    }

    // 其餘集合預設拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
